# ============================================================================
# .gitattributes — aap_config
# ============================================================================
# Trainees work on Windows desktops. Force LF line endings on everything text so
# a Windows checkout doesn't rewrite CRLF into YAML/shell and break ansible or
# the pre-commit hooks. Shell scripts and YAML MUST stay LF.
* text=auto eol=lf

*.sh    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.py    text eol=lf

# Binary assets — never normalize.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.pdf   binary
