# ============================================================================
# .devcontainer/Containerfile — aap_config dev container
# ============================================================================
# A lightweight Ansible control node for running the export/config playbooks as
# LOCAL API calls. Deliberately NOT an execution-environment and NOT
# ansible-navigator: everything here is connection: local, and EE-in-container on
# Docker/Podman Desktop for Windows is the #1 support burden for this audience.
# Execution environments are introduced conceptually later (runbook 10).
#
# Base: Red Hat UBI9 + Python 3.12 (matches the Red Hat platform story).
# ============================================================================
FROM registry.access.redhat.com/ubi9/python-312:latest

# ansible-core is pinned to the 2.16 stream to match the AAP 2.6 execution
# environment baseline (measured: the 2.6 ee-supported-rhel9 image ships
# ansible-core 2.16.17), because initial testing targets AAP 2.6. All pinned
# collections require only ">=2.16.0", so this satisfies them.
# CUTOVER TO 2.7: bump to ">=2.18,<2.19" (the AAP 2.7 EE baseline) when the
# on-prem environments move to 2.7. See CHANGELOG / ROADMAP.
#   podman run --rm registry.redhat.io/ansible-automation-platform-26/ee-supported-rhel9 ansible --version
ARG ANSIBLE_CORE_VERSION=">=2.16,<2.17"

# The GitHub CLI is installed here from the official release tarball rather than
# via ghcr.io/devcontainers/features/github-cli. That feature's install script is
# apt-only, so on this UBI9 base it fails the build outright:
#   ./install.sh: line 101: apt-get: command not found   (exit 127)
# Do NOT re-add the feature. (The node feature is fine — it supports dnf.)
# Bump this pin the way ANSIBLE_CORE_VERSION is bumped; releases are at
#   https://github.com/cli/cli/releases
ARG GH_VERSION=2.96.0

USER 0
RUN dnf -y install git openssh-clients jq tar && dnf clean all

# Arch-detected so an arm64 host doesn't silently get an x86_64 binary.
RUN set -eux; \
    case "$(uname -m)" in \
      x86_64)  gh_arch=amd64 ;; \
      aarch64) gh_arch=arm64 ;; \
      *) echo "unsupported arch: $(uname -m)" >&2; exit 1 ;; \
    esac; \
    curl -fsSL -o /tmp/gh.tar.gz \
      "https://github.com/cli/cli/releases/download/v${GH_VERSION}/gh_${GH_VERSION}_linux_${gh_arch}.tar.gz"; \
    tar -xzf /tmp/gh.tar.gz -C /usr/local --strip-components=1; \
    rm -f /tmp/gh.tar.gz; \
    gh --version

# Named, not numeric: dev container features receive this value as
# _DEV_CONTAINERS_IMAGE_USER and pass it to usermod, which needs a real user
# name. With "USER 1001" the node feature dies on "usermod: user '1001' does not
# exist". "default" is UBI9's uid-1001 application user, so this is the same
# account either way.
USER default
RUN python3 -m pip install --no-cache-dir --upgrade pip \
 && python3 -m pip install --no-cache-dir \
      "ansible-core${ANSIBLE_CORE_VERSION}" \
      ansible-lint \
      yamllint

# Collections are installed at post-create (not build time) so requirements.yml
# bumps don't force an image rebuild, and because the Automation Hub token isn't
# available during the build.
