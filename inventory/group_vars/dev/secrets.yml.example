---
# Copy to secrets.yml, fill in values, then encrypt:
#   ansible-vault encrypt inventory/group_vars/dev/secrets.yml --vault-id dev@prompt
aap_username: "CHANGEME"
aap_password: "CHANGEME"

# CaC object secrets — add vaulted_* variables here as you curate objects.
# Run `bash utilities/list-vaulted-vars.sh` to see which ones your objects need.
# vaulted_machine_password: "CHANGEME"
# vaulted_scm_ssh_key: "CHANGEME"

# Automation Analytics service account (console.redhat.com).
# REQUIRED — group_vars/aap/controller_settings.yml references both, so an
# apply to dev fails with an undefined variable if they are missing.
vaulted_subscriptions_client_id: "CHANGEME"
vaulted_subscriptions_client_secret: "CHANGEME"
