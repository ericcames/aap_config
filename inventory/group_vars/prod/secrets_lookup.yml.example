---
# CaC object secrets resolved from BeyondTrust Password Safe — shared by
# prod_active and prod_passive.
#
# ONLY for environments that manage secrets in Password Safe instead of
# ansible-vault. See docs/secrets-beyondtrust.md. If prod uses the default vault
# flow (runbook 04), ignore this file and put vaulted_* values in secrets.yml.
#
# Copy to secrets_lookup.yml. This file is COMMITTED IN PLAINTEXT and must stay
# that way: every value is a lazy lookup, never a secret. Never paste a real
# secret here, and never rename this file to secrets.yml.
#
# Requires (in the vault-encrypted secrets.yml): vaulted_bt_client_id,
# vaulted_bt_client_secret. And (in beyondtrust.yml): bt_api_url, bt_verify_ca.
#
# Each vaulted_* variable must be defined HERE or in secrets.yml — never both.
# Files in this directory load alphabetically, so secrets.yml would silently win.
#
# Both prod sides resolve the same lookups, so both must reach Password Safe.
#
# retrieval_type: MANAGED_ACCOUNT -> secret_list is 'system_name/account_name'
#                 SECRET          -> secret_list is 'folder/secret_title'
# Use generic placeholder paths in committed files — never real system or
# account names.
#
# Run `bash utilities/list-vaulted-vars.sh` to see which variables your curated
# objects need, then define each one below.
#
# vaulted_machine_password: >-
#   {{ lookup('beyondtrust.secrets_safe.secrets_safe_lookup',
#             api_url=bt_api_url,
#             verify_ca=bt_verify_ca,
#             client_id=vaulted_bt_client_id,
#             client_secret=vaulted_bt_client_secret,
#             retrieval_type='MANAGED_ACCOUNT',
#             secret_list='generic-system/generic-account') | first }}
